pm_api_url          = "https://pve.example.com:8006/api2/json"
pm_api_token_id     = "root@pam!provider"
pm_api_token_secret = "PASTE_NEW_SECRET_HERE"
pm_tls_insecure     = true

proxmox_node        = "littledown"
resource_profile    = "balanced_32gb"
build_inventory_file = "../ansible/inventories/production/build_inventory.yml"
site_config_file    = "../ansible/inventories/production/site_config.yml"
vm_template_vmid    = 9000
vm050_mint_template_vmid = 9050
# Set this later, after the Proxmox host is built and the RTX 3060 PCI address
# is known from lspci, for example "0000:02:00". Leave blank for now.
vm210_gpu_pci_address = ""
vm_storage          = "local-lvm"
vm050_mint_nvme_storage = "local-lvm"
vm050_mint_media_storage = "local-lvm"
lxc_storage         = "local-lvm"
cloudinit_storage   = "local-lvm"
# vmbr1 is the dedicated pfSense WAN bridge on nic1.
pfsense_wan_bridge  = "vmbr1"
# vmbr2 is the trusted internal LAN trunk on nic2.
pfsense_lan_bridge  = "vmbr2"
# vmbr3 is the DMZ/untrusted bridge for isolated or public-facing workloads.
pfsense_dmz_bridge  = "vmbr3"
debian_lxc_template = "local:vztmpl/debian-12-standard_12.12-1_amd64.tar.zst"

ansible_user   = "ansible"
ssh_public_key = "ssh-ed25519 AAAA_REPLACE_ME"
