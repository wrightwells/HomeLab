server {
    listen 80;
    listen [::]:80;
    server_name {{ item.server_name }};

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ item.server_name }};

    ssl_certificate     {{ nginx_certificates[item.certificate].fullchain }};
    ssl_certificate_key {{ nginx_certificates[item.certificate].privkey }};

    ssl_protocols {{ nginx_tls_protocols | join(' ') }};
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
{% if nginx_enable_hsts %}
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
{% endif %}

    include /etc/nginx/conf.d/proxy-common.conf;

    location / {
        proxy_pass {{ item.upstream }};
    }
}