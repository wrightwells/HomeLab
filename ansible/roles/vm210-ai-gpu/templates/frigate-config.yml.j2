version: 0.17-0

#####################################################################
# MQTT
#####################################################################

mqtt:
  enabled: true
  host: infra-01.bandicoot-pumpkinseed.ts.net
  user: mqtt_user
  password: mirror

#####################################################################
# NVIDIA / ONNX DETECTOR
#
# Requires Docker image:
#   ghcr.io/blakeblackshear/frigate:stable-tensorrt
#
# Required host model path:
#   {{ frigate_model_host_path }}
#
# Container path:
#   {{ frigate_model_path }}
#
# The model must be a Frigate-compatible YOLO ONNX model.
#####################################################################

detectors:
  onnx:
    type: onnx
    device: GPU

model:
  model_type: yolo-generic
  width: 320
  height: 320
  input_tensor: nchw
  input_dtype: float
  path: {{ frigate_model_path }}
  labelmap_path: /labelmap/coco-80.txt

#####################################################################
# GLOBAL DETECTION
#####################################################################

detect:
  enabled: true
  fps: 5

#####################################################################
# OBJECTS
#####################################################################

objects:
  track:
    - person
    - car

  genai:
    enabled: false

#####################################################################
# REVIEW SETTINGS
#####################################################################

review:
  alerts:
    labels: []
  detections:
    labels:
      - car
      - person

#####################################################################
# SEMANTIC SEARCH
#####################################################################

semantic_search:
  enabled: false
  model_size: large

#####################################################################
# FACE RECOGNITION
#####################################################################

face_recognition:
  enabled: true
  model_size: large
  device: GPU
  detection_threshold: 0.5
  recognition_threshold: 0.75
  unknown_score: 0.65
  min_area: 100
  min_faces: 1
  save_attempts: 200
  blur_confidence_filter: false

#####################################################################
# LICENSE PLATE RECOGNITION / LPR
#####################################################################

lpr:
  enabled: true
  device: GPU
  model_size: small
  detection_threshold: 0.5
  recognition_threshold: 0.6
  min_area: 250
  min_plate_length: 4
  match_distance: 1
  known_plates: {}
  enhancement: 0
  debug_save_plates: true
  replace_rules: []

#####################################################################
# OLLAMA GENAI PROVIDER
#####################################################################

genai:
  provider: ollama
  base_url: http://ai-gpu.bandicoot-pumpkinseed.ts.net:11434
  model: qwen3-vl:4b

#####################################################################
# CLASSIFICATION
#####################################################################

classification:
  custom:
    Car:
      enabled: true
      name: Car
      threshold: 0.8
      object_config:
        objects:
          - car
        classification_type: sub_label

  bird:
    enabled: false

#####################################################################
# CAMERAS
#####################################################################

cameras:
  Littledown_front:
    enabled: true

    ffmpeg:
      input_args: preset-rtsp-restream
      inputs:
        - path: rtsp://admin:m1rr0r00@10.10.1.65:554/h264Preview_01_main
          roles:
            - detect
            - record
      output_args:
        record: preset-record-generic-audio-copy

    detect:
      enabled: true
      width: 1920
      height: 1080
      fps: 5

    record:
      enabled: true
      alerts:
        retain:
          days: 1
          mode: motion
      detections:
        retain:
          days: 1
          mode: motion

    objects:
      track:
        - person
        - car
      filters:
        person:
          min_area: 1000
          max_area: 200000
        car:
          min_area: 5000

    snapshots:
      enabled: true
      timestamp: true
      bounding_box: true
      crop: false
      retain:
        default: 1

    motion:
      threshold: 30
      contour_area: 24
      improve_contrast: true

    face_recognition:
      enabled: true
      min_area: 100

    lpr:
      enabled: true
      min_area: 250
      enhancement: 0

  Goue:
    enabled: true

    ffmpeg:
      input_args: preset-rtsp-restream
      inputs:
        - path: rtsp://admin:m1rr0r00@10.20.1.11:554/h264Preview_01_sub
          roles:
            - detect
        - path: rtsp://admin:m1rr0r00@10.20.1.11:554/h264Preview_01_main
          roles:
            - record
      output_args:
        record: preset-record-generic-audio-copy

    detect:
      enabled: true
      width: 640
      height: 360
      fps: 5

    record:
      enabled: true
      alerts:
        retain:
          days: 1
          mode: motion
      detections:
        retain:
          days: 1
          mode: motion

    objects:
      track:
        - person
        - car
      filters:
        person:
          min_area: 1000
          max_area: 200000
        car:
          min_area: 5000

    snapshots:
      enabled: true
      timestamp: true
      bounding_box: true
      crop: false
      retain:
        default: 1

    motion:
      threshold: 30
      contour_area: 24
      improve_contrast: true

    face_recognition:
      enabled: true
      min_area: 100

    lpr:
      enabled: true
      min_area: 250
      enhancement: 0
