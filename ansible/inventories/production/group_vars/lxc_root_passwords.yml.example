---
# Example values for ansible/playbooks/lxc-root-password.yml
#
# 1. Generate a password hash:
#    openssl passwd -6 'replace-with-your-password'
#
# 2. Create or refresh the vaulted file:
#    cd ansible
#    ANSIBLE_LOCAL_TEMP=/tmp/ansible-local TMPDIR=/tmp \
#      ansible-vault encrypt_string \
#      --vault-password-file ~/.config/ansible/homelab-vault-pass.txt \
#      '$6$replace-with-your-generated-hash' \
#      --name 'lxc_root_password_hash'
#
# 3. Paste the encrypted output into:
#    inventories/production/group_vars/lxc_root_passwords.vault.yml

lxc_root_password_hash: "$6$replace-with-your-generated-hash"
