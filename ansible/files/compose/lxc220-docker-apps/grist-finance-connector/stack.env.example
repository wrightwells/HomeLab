# Runtime
IMAGE_TAG=0.1.0
LOG_LEVEL=INFO
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8080
SCHEDULER_ENABLED=false
RUN_SYNC_ON_STARTUP=false
ENABLE_MANUAL_SYNC_ENDPOINT=true

# Grist
GRIST_BASE_URL=http://grist:8484
GRIST_DOC_ID=replace_me
GRIST_API_KEY=replace_me
GRIST_TRANSACTIONS_TABLE=Raw_Import_Transactions
GRIST_ACCOUNTS_TABLE=Accounts
GRIST_SPACES_TABLE=Spaces
GRIST_IMPORT_LOG_TABLE=Import_Log
GRIST_EXTERNAL_ID_COLUMN=external_id
GRIST_SOURCE_COLUMN=source_name
GRIST_TRANSACTION_DATE_COLUMN=transaction_date
GRIST_DESCRIPTION_COLUMN=description
GRIST_AMOUNT_COLUMN=amount
GRIST_CURRENCY_COLUMN=currency
GRIST_ACCOUNT_ID_COLUMN=account_id
GRIST_EXTERNAL_REFERENCE_COLUMN=external_reference
GRIST_ACCOUNT_NAME_COLUMN=account_name
GRIST_ACCOUNT_TYPE_COLUMN=account_type
GRIST_SPACE_ID_COLUMN=space_id
GRIST_SPACE_NAME_COLUMN=space_name
GRIST_SPACE_BALANCE_COLUMN=space_balance
GRIST_SPACE_TARGET_COLUMN=space_target
GRIST_SPACE_TRANSACTIONS_COLUMN=space_transactions

# Source: Starling Bank
SOURCE_PROVIDER=starling
SOURCE_NAME=starling_bank
SOURCE_ENABLED=true
SOURCE_SCHEDULE=0 * * * *

STARLING_API_BASE_URL=https://api.starlingbank.com
STARLING_ACCESS_TOKEN=
STARLING_ACCESS_TOKENS=
STARLING_ACCOUNT_UID=
STARLING_ACCOUNT_UIDS=

# Sync behaviour
IMPORT_LOOKBACK_DAYS=30
DUPLICATE_MODE=skip_existing
DRY_RUN=true
BATCH_SIZE=100

# State / retries
STATE_DB_PATH=/data/state/connector.sqlite3
RETRY_COUNT=3
RETRY_BACKOFF_MS=1000
API_TIMEOUT_MS=15000
